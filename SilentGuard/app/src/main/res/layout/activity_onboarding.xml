<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl">

            <!-- Hero Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xl">

                <!-- Gradient Background -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:background="@drawable/gradient_primary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <!-- Large Icon -->
                <ImageView
                    android:id="@+id/heroIcon"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_shield_large"
                    android:padding="@dimen/spacing_lg"
                    android:layout_marginTop="@dimen/spacing_xl"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Welcome Text -->
                <TextView
                    android:id="@+id/welcomeTitle"
                    style="@style/Text.H1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome to\nSilent Guard"
                    android:textColor="@color/text_inverse"
                    android:textAlignment="center"
                    android:layout_marginTop="@dimen/spacing_lg"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/heroIcon" />

                <TextView
                    android:id="@+id/welcomeSubtitle"
                    style="@style/Text.Body"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Protection when you need it most"
                    android:textColor="@color/overlay_light"
                    android:textAlignment="center"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_xl"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:layout_marginEnd="@dimen/spacing_lg"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/welcomeTitle"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Features Section -->
            <TextView
                style="@style/Text.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How Silent Guard Protects You"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Feature Card 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:src="@drawable/ic_mic"
                        android:tint="@color/primary"
                        android:padding="@dimen/spacing_sm"
                        android:background="@drawable/circle_primary_light" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_md">

                        <TextView
                            style="@style/Text.Body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Audio Analysis"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/Text.BodySecondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Detects distress sounds using AI" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_check_circle"
                        android:tint="@color/success" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Feature Card 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:src="@drawable/ic_motion"
                        android:tint="@color/primary"
                        android:padding="@dimen/spacing_sm"
                        android:background="@drawable/circle_primary_light" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_md">

                        <TextView
                            style="@style/Text.Body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Motion Detection"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/Text.BodySecondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recognizes panic and fall patterns" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_check_circle"
                        android:tint="@color/success" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Feature Card 3 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xl"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:src="@drawable/ic_lock"
                        android:tint="@color/primary"
                        android:padding="@dimen/spacing_sm"
                        android:background="@drawable/circle_primary_light" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_md">

                        <TextView
                            style="@style/Text.Body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Privacy First"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/Text.BodySecondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All processing on-device, no cloud" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_check_circle"
                        android:tint="@color/success" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Contact Section -->
            <TextView
                style="@style/Text.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Trusted Contact"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <TextView
                style="@style/Text.BodySecondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="They'll receive an SMS alert in emergencies"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Contact Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/elevation_sm"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <!-- Name Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/nameInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_md"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="@color/background_tertiary"
                        app:boxCornerRadiusTopStart="@dimen/radius_sm"
                        app:boxCornerRadiusTopEnd="@dimen/radius_sm"
                        app:boxCornerRadiusBottomStart="@dimen/radius_sm"
                        app:boxCornerRadiusBottomEnd="@dimen/radius_sm"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/contactNameInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Contact Name"
                            android:inputType="textPersonName" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Phone Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/phoneInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="@color/background_tertiary"
                        app:boxCornerRadiusTopStart="@dimen/radius_sm"
                        app:boxCornerRadiusTopEnd="@dimen/radius_sm"
                        app:boxCornerRadiusBottomStart="@dimen/radius_sm"
                        app:boxCornerRadiusBottomEnd="@dimen/radius_sm"
                        app:startIconDrawable="@drawable/ic_phone"
                        app:startIconTint="@color/primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/contactPhoneInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Phone Number"
                            android:inputType="phone" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Add Contact Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/addContactButton"
                style="@style/Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_md"
                android:text="Add Contact"
                app:icon="@drawable/ic_add"
                app:iconGravity="textStart" />

            <!-- Contact Count -->
            <TextView
                android:id="@+id/contactCountText"
                style="@style/Text.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 contacts added"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_gravity="center" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Continue Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/continueButton"
        style="@style/Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height_lg"
        android:text="Continue"
        android:layout_margin="@dimen/spacing_lg"
        android:layout_gravity="bottom"
        android:enabled="false"
        app:icon="@drawable/ic_arrow_forward"
        app:iconGravity="end" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
