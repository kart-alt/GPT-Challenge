<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary"
    tools:context=".ui.MainActivity">

    <!-- AppBar with Gradient -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_primary"
        android:elevation="0dp"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_lg">

            <!-- Logo & Title -->
            <ImageView
                android:id="@+id/appLogo"
                android:layout_width="@dimen/icon_lg"
                android:layout_height="@dimen/icon_lg"
                android:src="@drawable/ic_shield_gradient"
                android:contentDescription="Silent Guard Logo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/appTitle"
                style="@style/Text.H2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Silent Guard"
                android:textColor="@color/text_inverse"
                android:layout_marginStart="@dimen/spacing_md"
                app:layout_constraintStart_toEndOf="@id/appLogo"
                app:layout_constraintTop_toTopOf="@id/appLogo"
                app:layout_constraintBottom_toBottomOf="@id/appLogo" />

            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings"
                android:tint="@color/text_inverse"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Status Card with Gradient -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statusCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardCornerRadius="@dimen/radius_xl"
                app:cardElevation="@dimen/elevation_lg"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gradient_status"
                    android:padding="@dimen/spacing_xl">

                    <!-- Status Icon (Animated) -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/statusIcon"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_shield_check"
                        android:tint="@color/text_inverse"
                        android:padding="@dimen/spacing_md"
                        android:background="@drawable/circle_white_translucent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Status Text -->
                    <TextView
                        android:id="@+id/statusText"
                        style="@style/Text.H2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protection Active"
                        android:textColor="@color/text_inverse"
                        android:layout_marginTop="@dimen/spacing_md"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/statusIcon" />

                    <!-- Status Description -->
                    <TextView
                        android:id="@+id/statusDescription"
                        style="@style/Text.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monitoring your safety 24/7"
                        android:textColor="@color/overlay_light"
                        android:layout_marginTop="@dimen/spacing_xs"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/statusText" />

                    <!-- Detection Stats Row -->
                    <LinearLayout
                        android:id="@+id/scoresRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:gravity="center"
                        app:layout_constraintTop_toBottomOf="@id/statusDescription">

                        <!-- Audio Score -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/audioScore"
                                style="@style/Text.H3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="@color/text_inverse" />

                            <TextView
                                style="@style/Text.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Audio"
                                android:textColor="@color/overlay_light" />

                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="@color/overlay_light" />

                        <!-- Motion Score -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/motionScore"
                                style="@style/Text.H3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="@color/text_inverse" />

                            <TextView
                                style="@style/Text.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Motion"
                                android:textColor="@color/overlay_light" />

                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="@color/overlay_light" />

                        <!-- Confidence Score -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/confidenceText"
                                style="@style/Text.H3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="@color/text_inverse" />

                            <TextView
                                style="@style/Text.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Confidence"
                                android:textColor="@color/overlay_light" />

                        </LinearLayout>

                    </LinearLayout>
                    
                    <!-- Real-time Live Chart -->
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/liveChart"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="@dimen/spacing_md"
                        app:layout_constraintTop_toBottomOf="@id/scoresRow" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Actions -->
            <TextView
                style="@style/Text.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:layout_marginBottom="@dimen/spacing_md" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_lg">

                <!-- Mode Card: Normal -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/normalModeCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardElevation="@dimen/elevation_sm"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="@dimen/icon_md"
                            android:layout_height="@dimen/icon_md"
                            android:src="@drawable/ic_shield"
                            android:tint="@color/primary" />

                        <TextView
                            style="@style/Text.Body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Normal"
                            android:layout_marginTop="@dimen/spacing_xs" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Mode Card: Gym -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/gymModeCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardElevation="@dimen/elevation_sm">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="@dimen/icon_md"
                            android:layout_height="@dimen/icon_md"
                            android:src="@drawable/ic_fitness"
                            android:tint="@color/text_secondary" />

                        <TextView
                            style="@style/Text.Body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gym"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Mode Card: Concert -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/concertModeCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardElevation="@dimen/elevation_sm">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="@dimen/icon_md"
                            android:layout_height="@dimen/icon_md"
                            android:src="@drawable/ic_music"
                            android:tint="@color/text_secondary" />

                        <TextView
                            style="@style/Text.Body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Concert"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Features List -->
            <TextView
                style="@style/Text.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How It Works"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Feature Item 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_md"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_mic"
                    android:tint="@color/primary"
                    android:padding="@dimen/spacing_xs"
                    android:background="@drawable/circle_primary_light" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/spacing_md">

                    <TextView
                        style="@style/Text.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Audio Detection"
                        android:textStyle="bold" />

                    <TextView
                        style="@style/Text.BodySecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Analyzes distress sounds in real-time" />

                </LinearLayout>

            </LinearLayout>

            <!-- Feature Item 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_md"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_motion"
                    android:tint="@color/primary"
                    android:padding="@dimen/spacing_xs"
                    android:background="@drawable/circle_primary_light" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/spacing_md">

                    <TextView
                        style="@style/Text.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Motion Analysis"
                        android:textStyle="bold" />

                    <TextView
                        style="@style/Text.BodySecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detects panic, falls, and struggle patterns" />

                </LinearLayout>

            </LinearLayout>

            <!-- Feature Item 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_brain"
                    android:tint="@color/primary"
                    android:padding="@dimen/spacing_xs"
                    android:background="@drawable/circle_primary_light" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/spacing_md">

                    <TextView
                        style="@style/Text.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smart Context"
                        android:textStyle="bold" />

                    <TextView
                        style="@style/Text.BodySecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prevents false alarms with AI awareness" />

                </LinearLayout>

            </LinearLayout>

            <!-- Privacy Badge -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="@dimen/elevation_sm"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_lock"
                        android:tint="@color/success" />

                    <TextView
                        style="@style/Text.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Privacy-first • On-device AI • No cloud storage"
                        android:layout_marginStart="@dimen/spacing_sm" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/Text.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Demo Controls"
                android:layout_marginTop="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_sm">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/testAudioButton"
                    style="@style/Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:text="Test Audio" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/testMotionButton"
                    style="@style/Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:text="Test Motion" />
            </LinearLayout>

            <!-- Test Button (For Demo) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/testButton"
                style="@style/Button.Danger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TEST FULL ALERT (Demo)"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- View History Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/historyButton"
                style="@style/Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View Detection History"
                android:layout_marginBottom="@dimen/spacing_xl" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Floating Action Button (Toggle Protection) -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/toggleButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center"
        android:layout_margin="@dimen/spacing_lg"
        android:text="Start Protection"
        android:textColor="@color/text_inverse"
        app:icon="@drawable/ic_play"
        app:iconTint="@color/text_inverse"
        app:backgroundTint="@color/success"
        app:elevation="@dimen/elevation_lg" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
