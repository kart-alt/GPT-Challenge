<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_md"
    android:layout_marginVertical="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="@dimen/elevation_sm"
    app:strokeWidth="1dp"
    app:strokeColor="@color/overlay_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        android:gravity="center_vertical">

        <!-- Status Icon -->
        <ImageView
            android:id="@+id/historyIcon"
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:src="@drawable/ic_shield_check"
            android:tint="@color/primary"
            android:padding="@dimen/spacing_xs"
            android:background="@drawable/circle_primary_light" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_md">

            <TextView
                android:id="@+id/historyDecision"
                style="@style/Text.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIGH_CONFIDENCE"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/historyTime"
                style="@style/Text.BodySecondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oct 24, 10:30 AM" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/historyConfidence"
                style="@style/Text.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="95%"
                android:textColor="@color/text_inverse"
                android:background="@drawable/bg_rounded_primary"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="2dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
