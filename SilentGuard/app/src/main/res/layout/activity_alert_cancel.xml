<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_alert_background"
    android:padding="@dimen/spacing_xl">

    <!-- Animated Alert Icon -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/alertIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_alert_animated"
        android:tint="@color/text_inverse"
        android:padding="@dimen/spacing_lg"
        android:background="@drawable/circle_white_translucent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/alertTitleText"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Pulse Animation Background -->
    <View
        android:id="@+id/pulseRing1"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/circle_white_translucent"
        android:alpha="0.3"
        app:layout_constraintStart_toStartOf="@id/alertIcon"
        app:layout_constraintEnd_toEndOf="@id/alertIcon"
        app:layout_constraintTop_toTopOf="@id/alertIcon"
        app:layout_constraintBottom_toBottomOf="@id/alertIcon" />

    <View
        android:id="@+id/pulseRing2"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/circle_white_translucent"
        android:alpha="0.2"
        app:layout_constraintStart_toStartOf="@id/alertIcon"
        app:layout_constraintEnd_toEndOf="@id/alertIcon"
        app:layout_constraintTop_toTopOf="@id/alertIcon"
        app:layout_constraintBottom_toBottomOf="@id/alertIcon" />

    <!-- Alert Title -->
    <TextView
        android:id="@+id/alertTitleText"
        style="@style/Text.H1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EMERGENCY\nDETECTED"
        android:textColor="@color/text_inverse"
        android:textAlignment="center"
        android:letterSpacing="0.05"
        android:layout_marginTop="@dimen/spacing_xl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/alertIcon"
        app:layout_constraintBottom_toTopOf="@id/countdownLabel" />

    <!-- Countdown Label -->
    <TextView
        android:id="@+id/countdownLabel"
        style="@style/Text.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sending alert in"
        android:textColor="@color/overlay_light"
        android:layout_marginTop="@dimen/spacing_lg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/alertTitleText"
        app:layout_constraintBottom_toTopOf="@id/countdownCard" />

    <!-- Countdown Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/countdownCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        app:cardCornerRadius="@dimen/radius_xl"
        app:cardElevation="@dimen/elevation_md"
        app:cardBackgroundColor="@color/overlay_light"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/countdownLabel"
        app:layout_constraintBottom_toTopOf="@id/cancelButton">

        <TextView
            android:id="@+id/countdownText"
            style="@style/Text.Display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10.0"
            android:textColor="@color/alert_background"
            android:padding="@dimen/spacing_lg"
            android:minWidth="120dp"
            android:gravity="center"
            android:textStyle="bold" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Cancel Button (Large, Prominent) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancelButton"
        style="@style/Button.Primary"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="I'M SAFE - CANCEL"
        android:textSize="@dimen/text_h3"
        android:textStyle="bold"
        android:layout_marginTop="@dimen/spacing_xl"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        app:icon="@drawable/ic_close"
        app:iconSize="@dimen/icon_md"
        app:iconGravity="textStart"
        app:backgroundTint="@color/text_inverse"
        android:textColor="@color/alert_background"
        app:cornerRadius="@dimen/radius_lg"
        app:elevation="@dimen/elevation_lg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/countdownCard"
        app:layout_constraintBottom_toTopOf="@id/confirmButton" />

    <!-- Confirm Button (Secondary) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/confirmButton"
        style="@style/Button.Secondary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Send Alert Now"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        app:strokeColor="@color/text_inverse"
        android:textColor="@color/text_inverse"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cancelButton"
        app:layout_constraintBottom_toTopOf="@id/infoCard" />

    <!-- Info Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/infoCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:layout_marginBottom="@dimen/spacing_lg"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/overlay_light"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/confirmButton"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_md"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:src="@drawable/ic_info"
                android:tint="@color/text_inverse"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <TextView
                style="@style/Text.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Your trusted contacts will receive an SMS with your location if you don't cancel"
                android:textColor="@color/text_inverse"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
